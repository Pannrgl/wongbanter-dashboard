{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/ui/portfolio.html" },
    { "source": "/assets/:path*", "destination": "/ui/:path*" }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 10,
      "excludeFiles": "{gas.py,gas_original.py,mt5_orders.py}"
    }
  }
}
